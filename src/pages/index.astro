---
import Layout from '../layouts/Layout.astro';
import PriceCard from '../components/PriceCard';
import CategoryFilter from '../components/CategoryFilter';
import AdSlot from '../components/AdSlot.astro';
import { getAllItems, getLatestPrices, usingMock } from '../lib/data/client';
import { CATEGORIES } from '../lib/data/items';
import { formatDateKor } from '../lib/format';

const items = await getAllItems();
const prices = await getLatestPrices();
const today = formatDateKor(new Date());

// 실제 가격이 있는 품목만 노출 (실데이터에서 KAMIS 미수록 품목은 빠짐).
const visibleItems = items.filter((item) => prices.has(item.code));

// 데이터가 있는 카테고리만, CATEGORIES 순서대로 개수와 함께.
const countByCategory = new Map<string, number>();
for (const item of visibleItems) {
  countByCategory.set(item.category, (countByCategory.get(item.category) ?? 0) + 1);
}
const activeCategories = CATEGORIES.filter((c) => countByCategory.has(c.value)).map((c) => ({
  value: c.value,
  label: c.label,
  count: countByCategory.get(c.value) ?? 0,
}));

const AD_AFTER_INDEX = 11; // 12번째 카드 뒤에 인피드 광고
const firstSlice = visibleItems.slice(0, AD_AFTER_INDEX + 1);
const secondSlice = visibleItems.slice(AD_AFTER_INDEX + 1);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: '사장시세',
  url: Astro.site ? Astro.site.toString() : 'https://sajangsise.com/',
  description: `식당 사장님을 위한 오늘의 식자재 시세 — ${visibleItems.length}개 품목 소매가와 1년 추이. KAMIS 전국 평균 기준.`,
  inLanguage: 'ko',
};
---
<Layout
  title="오늘 식자재 시세 — 배추·삼겹살·수박 등 소매가 | 사장시세"
  description={`오늘 식자재 가격 한눈에 — 채소·축산·수산·과일 등 ${visibleItems.length}개 품목의 소매가와 어제 대비 변동. KAMIS 전국 평균, 매일 갱신.`}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  <main class="mx-auto w-full max-w-screen-xl px-4 pt-4 pb-12 flex-1">
    <section class="mb-4">
      <h1 class="text-2xl sm:text-3xl font-bold tracking-tight">오늘 식자재 시세</h1>
      <p class="text-sm text-neutral-500 mt-1 tabular-nums">{today} · 어제 대비 소매가</p>
    </section>

    <CategoryFilter categories={activeCategories} total={visibleItems.length} client:load />

    <div class="grid grid-cols-2 md:grid-cols-5 gap-2 mt-3">
      {firstSlice.map((item) => {
        const p = prices.get(item.code)!;
        return (
          <div data-category={item.category}>
            <PriceCard item={item} current={p.current} previous={p.previous} />
          </div>
        );
      })}
      <AdSlot slot="home-grid-mid" span="box" />
      {secondSlice.map((item) => {
        const p = prices.get(item.code)!;
        return (
          <div data-category={item.category}>
            <PriceCard item={item} current={p.current} previous={p.previous} />
          </div>
        );
      })}
    </div>

    <AdSlot slot="home-grid-bottom" span="banner" className="mt-4" />

    <p class="text-[11px] text-neutral-400 mt-6">
      {usingMock
        ? 'Phase 0 — mock 데이터로 운영 중. KAMIS Open API 키 발급 후 실제 데이터로 전환합니다.'
        : '가격 출처: KAMIS Open API 일별 품목별 소매가격(전국 평균). 매일 18시 갱신.'}
    </p>
  </main>
</Layout>
