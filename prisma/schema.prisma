// Phase 1 — Supabase Postgres 스키마. Phase 0에서는 사용하지 않음.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Item {
  id              Int      @id @default(autoincrement())
  code            String   @unique
  name            String
  category        String
  unit            String
  kamisCategoryId String?
  kamisItemId     String?
  kamisKindId     String?
  prices          Price[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Price {
  id        Int      @id @default(autoincrement())
  itemId    Int
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  wholesale Int?
  retail    Int?
  source    String   @default("kamis")
  createdAt DateTime @default(now())

  @@unique([itemId, date])
  @@index([date])
}
