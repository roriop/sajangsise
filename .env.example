# Phase 0: mock 데이터 사용 (KAMIS API 키 신청 중)
USE_KAMIS_MOCK=true

# Phase 1: 광고 슬롯 활성화 (false면 DOM에는 있지만 display:none)
ENABLE_ADS=false

# Phase 1: KAMIS Open API
KAMIS_API_KEY=
KAMIS_API_ID=

# Phase 1: Supabase Postgres (Prisma)
DATABASE_URL="postgresql://user:pass@host:5432/db?schema=public&pgbouncer=true"
DIRECT_URL="postgresql://user:pass@host:5432/db?schema=public"

# Phase 1: Supabase (선택)
SUPABASE_URL=
SUPABASE_ANON_KEY=
